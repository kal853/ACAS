rem %NOLIST
	REM ******************************************************************\
	    *								                                 *\
	    *	   OEPR2FIL.BAS       PARAMETER FILE 2 CONTROL MODULE	     *\
	    *								                                 *\
	    ******************************************************************

	REM ***  OPEN PARAMETER FILE 2	***

80100	IF END #2 THEN 80110
	FILE$="A:OEPR2FIL.101" : M%=173 : N%=2 : GOSUB 85100
	RETURN

80110	ERROR$="UNABLE TO OPEN PARAMETER FILE 2"
	GOTO 85000

	REM ***  READ PARAMETER FILE 2	***

80120	IF END #2 THEN 80130
	READ #2,1; PR2.NAME$, PR2.ADD1$, PR2.ADD2$, PR2.ADD3$, PR2.POSTCODE$,\
		PR2.TELNO$, PR2.VATREGNO$, PR2.CREDIT.TERMS%
	RETURN

80130	ERROR$="UNABLE TO READ PARAMETER FILE 2"
	GOTO 85000

	REM ***  WRITE PARAMETER FILE 2  ***

80140	PRINT #2,1; PR2.NAME$, PR2.ADD1$, PR2.ADD2$, PR2.ADD3$, PR2.POSTCODE$,\
		PR2.TELNO$, PR2.VATREGNO$, PR2.CREDIT.TERMS%
	RETURN

80145	ERROR$="UNABLE TO WRITE PARAMETER FILE 2"
	GOTO 85000

	REM ***  CREATE PARAMETER FILE 2  ***

80150	FILE$="A:OEPR2FIL.101" : M%=173 : N%=2 : GOSUB 85300
	RETURN

80155	ERROR$="UNABLE TO CREATE PARAMETER FILE 2"
	GOTO 85000
rem %LIST
