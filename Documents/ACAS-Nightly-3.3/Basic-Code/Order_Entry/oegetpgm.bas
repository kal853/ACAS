rem %NOLIST
	REM *****************************************************************\
	    *								                                *\
	    *	   OEGETPGM.BAS    ORDER ENTRY CALL PROGRAM MODULE	        *\
	    *								                                *\
	    *****************************************************************

90000	R%=ROW%(23) : C%=COL%(1)  : Z$="FUNCTION CODE [  ]" : GOSUB 12100
	R%=ROW%(23) : C%=COL%(16) : LENGTH%=2 : GOSUB 12200
	IF F%<>3 THEN 90001
	FUNCTION$=Z$
	FUNCTION%=VAL(FUNCTION$)
	IF FUNCTION%=99 THEN 90990
	IF FUNCTION%<1 OR FUNCTION%>15 THEN 90001
	ON FUNCTION% GOTO 90010,90020,90030,90040,90050,90060,90070,90080,\
		90090,90100,90110,90120,90130,90140,90150
90001	R%=ROW%(23) : C%=COL%(40) : Z$=BELL$+"INVALID FUNCTION - REENTER"+EOL$
	GOSUB 12100
	GOTO 90000

90010	PGM$="oe020"
	GOTO 90200
90020	PGM$="oe030"
	GOTO 90200
90030	PGM$="oe040"
	GOTO 90200
90040	PGM$="oe050"
	GOTO 90200
90050	PGM$="oe060"
	GOTO 90200
90060	PGM$="oe070"
	GOTO 90200
90070	PGM$="oe080"
	GOTO 90200
90080	PGM$="oe090a"
	GOTO 90200
90090	PGM$="oe100"
	GOTO 90200
90100	PGM$="oe110"
	GOTO 90200
90110	PGM$="oeuser1"
	GOTO 90200
90120	PGM$="oeuser2"
	GOTO 90200
90130	PGM$="oeuser3"
	GOTO 90200
90140	PGM$="oeuser4"
	GOTO 90200
90150	PGM$="oe120"
	GOTO 90200

90200	A$=PGM$+".INT" : A%=SIZE(A$)
	IF A%=0 THEN \
		R%=ROW%(23) : C%=COL%(40) :\
		Z$=BELL$+"THIS FUNCTION NOT AVAILABLE"+EOL$ : GOSUB 12100 :\
		GOTO 90000
	CHAIN PGM$

rem %LIST
90990	END
