rem %NOLIST
	REM ******************************************************************\
	    *								                                 *\
	    *	   OEPR3FIL.BAS       PARAMETER FILE 3 CONTROL MODULE	     *\
	    *								                                 *\
	    ******************************************************************

	REM ***  OPEN PARAMETER FILE 3	***

80200	IF END #3 THEN 80210
	FILE$="A:OEPR3FIL.101" : M%=49 : N%=3 : GOSUB 85100
	RETURN

80210	ERROR$="UNABLE TO OPEN PARAMETER FILE 3"
	GOTO 85000

	REM ***  READ PARAMETER FILE 3	***

80220	IF END #3 THEN 80230
	READ #3,1; PR3.DATE$, PR3.DATE%, PR3.ORDER.NO%, PR3.INVOICE.NO%,\
		PR3.STARTOF.DAY%, PR3.ENDOF.DAY%, PR3.LASTDATE$, PR3.LASTDATE%
	RETURN

80230	ERROR$="UNABLE TO READ PARAMETER FILE 3"
	GOTO 85000

	REM ***  WRITE PARAMETER FILE 3  ***

80240	PRINT #3,1; PR3.DATE$, PR3.DATE%, PR3.ORDER.NO%, PR3.INVOICE.NO%,\
		PR3.STARTOF.DAY%, PR3.ENDOF.DAY%, PR3.LASTDATE$, PR3.LASTDATE%
	RETURN

80245	ERROR$="UNABLE TO WRITE PARAMETER FILE 3"
	GOTO 85000

	REM ***  CREATE PARAMETER FILE 3  ***

80250	FILE$="A:OEPR3FIL.101" : M%=49 : N%=3 : GOSUB 85300
	RETURN

80255	ERROR$="UNABLE TO CREATE PARAMETER FILE 3"
	GOTO 85000
rem %LIST
