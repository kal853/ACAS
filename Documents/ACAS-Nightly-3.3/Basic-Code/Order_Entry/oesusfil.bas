REM %NOLIST
	REM ******************************************************************\
	    *								                                 *\
	    *	   OESUSFIL.BAS       MAIN SUSPENSE FILE CONTROL MODULE      *\
	    *								                                 *\
	    ******************************************************************

	REM ***  OPEN MAIN SUSPENSE FILE  ***

80400	FILE$=PR1.SUSP.DRV$+"OESUSFIL.101" : M%=205 : N%=5 : GOSUB 85100
	RETURN

80410	ERROR$="UNABLE TO OPEN MAIN SUSPENSE FILE"
	GOTO 85000

	REM ***  READ SUSPENSE FILE  ***

80420	READ #5,N%; S1.ORDNO%,	S1.RECTYPE%, S1.DEL%, S1.NEXTREC%, \
		S1.CUSTNAME$, S1.CUSTADD1$, S1.CUSTADD2$, S1.CUSTADD3$, \
		S1.POSTCODE$, S1.CUSTTEL$, S1.CUST.ORDNO$, S1.PAY%,\
		S1.REASON%, S1.DATE$, S1.DATE%, S1.INVOICE%
	RETURN

80422	ERROR$="UNABLE TO READ SUSPENSE REC TYPE 1"
	GOTO 85000

80424	READ #5,N%; S1.ORDNO%, S1.RECTYPE%, S1.DEL%, S1.NEXTREC%, S1.PARTNO$,\
		S1.PARTDESC$, S1.QUANTITY%, S1.PRICE, S1.VAT
	RETURN

80426	ERROR$="UNABLE TO READ SUSPENSE REC TYPE 2"
	GOTO 85000

80428	READ #5,N%; S1.ORDNO%, S1.RECTYPE%, S1.DEL%, S1.NEXTREC%,\
		S1.INV.NAME$, S1.INV.ADD1$, S1.INV.ADD2$, S1.INV.ADD3$,\
		S1.INV.POSTCODE$, S1.INV.TEL$
	RETURN

80430	ERROR$="UNABLE TO READ SUSPENSE REC TYPE 3"
	GOTO 85000

	REM ***  WRITE SUSPENSE RECORD TYPE 1  ***

80440	PRINT #5,N%; S1.ORDNO%, S1.RECTYPE%, S1.DEL%, S1.NEXTREC%, \
		S1.CUSTNAME$, S1.CUSTADD1$, S1.CUSTADD2$, S1.CUSTADD3$, \
		S1.POSTCODE$, S1.CUSTTEL$, S1.CUST.ORDNO$, S1.PAY%,\
		S1.REASON%, S1.DATE$, S1.DATE%, S1.INVOICE%
	RETURN

80445	ERROR$="UNABLE TO WRITE SUSPENSE RECORD TYPE 1"
	GOTO 85000

	REM ***  WRITE SUSPENSE RECORD 2  ***

80450	PRINT #5,N%; S1.ORDNO%, S1.RECTYPE%, S1.DEL%, S1.NEXTREC%, \
		S1.PARTNO$, S1.PARTDESC$, S1.QUANTITY%, S1.PRICE, S1.VAT
	RETURN

80455	ERROR$="UNABLE TO WRITE SUSPENSE RECORD TYPE 2"
	GOTO 85000

	REM ***  WRITE SUSPENSE RECORD 3  ***

80460	PRINT #5,N%; S1.ORDNO%, S1.RECTYPE%, S1.DEL%, S1.NEXTREC%,\
		S1.INV.NAME$, S1.INV.ADD1$, S1.INV.ADD2$, S1.INV.ADD3$,\
		S1.INV.POSTCODE$, S1.INV.TEL$
	RETURN

80465	ERROR$="UNABLE TO WRITE SUSPENSE RECORD TYPE 3"
	GOTO 85000

	REM ***  CREATE MAIN SUSPENSE FILE  ***

80470	FILE$=PR1.SUSP.DRV$+"OESUSFIL.101" : M%=205 : N%=5 : GOSUB 85300
	RETURN

80475	ERROR$="UNABLE TO CREATE MAIN SUSPENSE FILE"
	GOTO 85000
REM %LIST
