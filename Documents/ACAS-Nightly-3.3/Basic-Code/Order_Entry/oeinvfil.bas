rem %NOLIST
	REM ******************************************************************\
	    *								                                 *\
	    *	   OEINVFIL.BAS       INVOICE FILE CONTROL MODULE	         *\
	    *								                                 *\
	    ******************************************************************

	REM ***  OPEN INVOICE FILE  ***

80700	FILE$=PR1.INV.DRV$+"OEINVFIL.101" : N%=8 : GOSUB 85200
	RETURN

80710	ERROR$="UNABLE TO OPEN INVOICE FILE"
	GOTO 85000

	REM ***  READ INVOICE FILE  ***

80720	READ #8; I1.ORDNO%, I1.RECTYPE%
	RETURN

80722	READ #8; I1.CUSTNAME$, I1.CUSTADD1$, I1.CUSTADD2$, I1.CUSTADD3$,\
		I1.POSTCODE$, I1.CUSTORDNO$, I1.PAY%, I1.DATE$, I1.INVOICE.NO%
	RETURN

80724	READ #8; I1.PARTNO$, I1.PARTDESC$, I1.QUANTITY%, I1.PRICE, I1.VAT
	RETURN

80730	ERROR$="UNABLE TO READ INVOICE FILE"
	GOTO 85000

	REM ***  WRITE INVOICE RECORD TYPE 1  ***

80740	PRINT #8; I1.ORDNO%, I1.RECTYPE%, I1.CUSTNAME$, I1.CUSTADD1$,\
		I1.CUSTADD2$, I1.CUSTADD3$, I1.POSTCODE$, I1.CUSTORDNO$,\
		I1.PAY%, I1.DATE$, I1.INVOICE.NO%
	RETURN

80745	ERROR$="UNABLE TO WRITE INVOICE RECORD TYPE 1"
	GOTO 85000

	REM ***  WRITE INVOICE RECORD TYPE 2  ***

80750	PRINT #8; I1.ORDNO%, I1.RECTYPE%, I1.PARTNO$, I1.PARTDESC$,\
		I1.QUANTITY%, I1.PRICE, I1.VAT
	RETURN

80755	ERROR$="UNABLE TO WRITE INVOICE RECORD TYPE 2"
	GOTO 85000

	REM ***  CREATE INVOICE FILE  ***

80760	FILE$=PR1.INV.DRV$+"OEINVFIL.101" : N%=8 : GOSUB 85400
	RETURN

80765	ERROR$="UNABLE TO CREATE INVOICE FILE"
	GOTO 85000
rem %LIST
