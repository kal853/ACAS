	REM ***************************************************************** \
	    *								                                * \
	    *	   OE110.BAS	   ORDER ENTRY PARAMETER FILES UPDATE PGM   * \
	    *								                                * \
	    *****************************************************************

%include oecommon

	DIM PR1.PASSWORD$(3), PR1.CREDCARD.CODE%(4), PR1.CREDCARD.NAME$(4),   \
		DEFAULT$(35)

	CONSOLE
	FOR I=1 TO 24 : PRINT : NEXT I
	PRINT "THIS FUNCTION ALLOWS YOU TO CHANGE THE VARIOUS PARAMETERS";    \
	      " USED BY THE SYSTEM."
	PRINT "EACH QUESTION WILL BE FOLLOWED BY THE DEFAULT ANSWER. ENTER";  \
	      " <CR> FOR THE DEFAULT"
	PRINT

	REM ***  DELETE ANY EXISTING BACKUP FILES  ***

	N%=11
	FOR I%=1 TO 3
		IF I%=1 THEN FILE$="oepr1fil.201"
		IF I%=2 THEN FILE$="oepr2fil.201"
		IF I%=3 THEN FILE$="oepr3fil.201"
		IF END #N% THEN 1
		GOSUB 85200
		DELETE 11
1	NEXT I%

	REM ***  BACKUP PARAMETER FILE 1  ***

	N%=11 : M%=218 : FILE$="oepr1fil.201"
	IF END #N% THEN 80010
	Z%=RENAME(FILE$,"oepr1fil.101")
	IF Z%=-1 THEN GOSUB 85100 :					      \
		READ #N%,1; PR1.PASSWORD$(1), PR1.PASSWORD$(2), 	      \
			PR1.PASSWORD$(3), PR1.CREDCARD.CODE%(1),	      \
			PR1.CREDCARD.CODE%(2), PR1.CREDCARD.CODE%(3),	      \
			PR1.CREDCARD.CODE%(4), PR1.CREDCARD.NAME$(1),	      \
			PR1.CREDCARD.NAME$(2), PR1.CREDCARD.NAME$(3),	      \
			PR1.CREDCARD.NAME$(4), PR1.ORDNO.GEN%,		      \
			PR1.INVNO.GEN%, PR1.DISP.DRV$, PR1.SUSP.DRV$,	      \
			PR1.INV.DRV$, PR1.CRED.DRV$, PR1.STOCKFIL.IND%,       \
			PR1.STOCKFIL.DRV$, PR1.STOCKFIL.NAME$,		      \
			PR1.CUSTFIL.IND%, PR1.CUSTFIL.DRV$, PR1.CUSTFIL.NAME$,\
			PR1.SALESFIL.IND%, PR1.SALESFIL.DRV$,		      \
			PR1.SALESFIL.NAME$, PR1.VDUDEF.NAME$ :		      \
		CLOSE N% : END.FLAG1=0					      \
	ELSE PRINT "WARNING - PARAMETER FILE 1 DOES NOT EXIST" : END.FLAG1=1

	REM ***  BACKUP PARAMETER FILE 2  ***

	N%=12 : M%=173 : FILE$="oepr2fil.201"
	IF END #N% THEN 80110
	Z%=RENAME(FILE$,"oepr2fil.101")
	IF Z%=-1 THEN GOSUB 85100 :					      \
		READ #N%,1; PR2.NAME$, PR2.ADD1$, PR2.ADD2$, PR2.ADD3$,       \
			PR2.POSTCODE$, PR2.TELNO$, PR2.VATREGNO$,	      \
			PR2.CREDIT.TERMS% :				      \
		CLOSE N% : END.FLAG2=0					      \
	ELSE PRINT "WARNING - PARAMETER FILE 2 DOES NOT EXIST" : END.FLAG2=1

	REM ***  SET UP DEFAULT VALUES	***

	IF END.FLAG1=1 THEN 2
	DEFAULT$(1) =PR1.PASSWORD$(1)
	DEFAULT$(2) =PR1.PASSWORD$(2)
	DEFAULT$(3) =PR1.PASSWORD$(3)
	DEFAULT$(4) =STR$(PR1.CREDCARD.CODE%(1))
	DEFAULT$(5) =STR$(PR1.CREDCARD.CODE%(2))
	DEFAULT$(6) =STR$(PR1.CREDCARD.CODE%(3))
	DEFAULT$(7) =STR$(PR1.CREDCARD.CODE%(4))
	DEFAULT$(8) =PR1.CREDCARD.NAME$(1)
	DEFAULT$(9) =PR1.CREDCARD.NAME$(2)
	DEFAULT$(10)=PR1.CREDCARD.NAME$(3)
	DEFAULT$(11)=PR1.CREDCARD.NAME$(4)
	IF PR1.ORDNO.GEN%=1 THEN DEFAULT$(12)="YES"                           \
	ELSE DEFAULT$(12)="NO"
	IF PR1.INVNO.GEN%=1 THEN DEFAULT$(13)="YES"                           \
	ELSE DEFAULT$(13)="NO"
	DEFAULT$(14)=LEFT$(PR1.DISP.DRV$,1)
	DEFAULT$(15)=LEFT$(PR1.SUSP.DRV$,1)
	DEFAULT$(16)=LEFT$(PR1.INV.DRV$,1)
	DEFAULT$(17)=LEFT$(PR1.CRED.DRV$,1)
	IF PR1.STOCKFIL.IND%=1 THEN DEFAULT$(18)="YES"  :                     \
		DEFAULT$(19)=LEFT$(PR1.STOCKFIL.DRV$,1) :		      \
		DEFAULT$(20)=PR1.STOCKFIL.NAME$ 			      \
	ELSE DEFAULT$(18)="NO" : DEFAULT$(19)="NULL" : DEFAULT$(20)="NULL"
	IF PR1.CUSTFIL.IND%=1 THEN DEFAULT$(21)="YES"  :                      \
		DEFAULT$(22)=LEFT$(PR1.CUSTFIL.DRV$,1) :		      \
		DEFAULT$(23)=PR1.CUSTFIL.NAME$				      \
	ELSE DEFAULT$(21)="NO" : DEFAULT$(22)="NULL" : DEFAULT$(23)="NULL"
	IF PR1.SALESFIL.IND%=1 THEN DEFAULT$(24)="YES"  :                     \
		DEFAULT$(25)=LEFT$(PR1.SALESFIL.DRV$,1) :		      \
		DEFAULT$(26)=PR1.SALESFIL.NAME$ 			      \
	ELSE DEFAULT$(24)="NO" : DEFAULT$(25)="NULL" : DEFAULT$(26)="NULL"
	DEFAULT$(27)=PR1.VDUDEF.NAME$
	GOTO 3

2	DEFAULT$(1) ="NULL" : DEFAULT$(2) ="NULL"      : DEFAULT$(3) ="NULL"
	DEFAULT$(4) ="0"    : DEFAULT$(5) ="0"         : DEFAULT$(6) ="0"
	DEFAULT$(7) ="0"    : DEFAULT$(8) ="NULL"      : DEFAULT$(9) ="NULL"
	DEFAULT$(10)="NULL" : DEFAULT$(11)="NULL"      : DEFAULT$(12)="NO"
	DEFAULT$(13)="NO"   : DEFAULT$(14)="B"         : DEFAULT$(15)="B"
	DEFAULT$(16)="B"    : DEFAULT$(17)="B"         : DEFAULT$(18)="NO"
	DEFAULT$(19)="B"    : DEFAULT$(20)="iyprt.101" : DEFAULT$(21)="NO"
	DEFAULT$(22)="B"    : DEFAULT$(23)="apcus.101" : DEFAULT$(24)="NO"
	DEFAULT$(25)="B"    : DEFAULT$(26)="arrec.101"
	DEFAULT$(27)="ELBIT.DEF"

3	IF END.FLAG2=1 THEN 4
	DEFAULT$(28)=PR2.NAME$	   : DEFAULT$(29)=PR2.ADD1$
	DEFAULT$(30)=PR2.ADD2$	   : DEFAULT$(31)=PR2.ADD3$
	DEFAULT$(32)=PR2.POSTCODE$ : DEFAULT$(33)=PR2.TELNO$
	DEFAULT$(34)=PR2.VATREGNO$
	DEFAULT$(35)=STR$(PR2.CREDIT.TERMS%)+" DAYS"
	GOTO 4.5

4	DEFAULT$(28)="NULL" : DEFAULT$(29)="NULL" : DEFAULT$(30)="NULL"
	DEFAULT$(31)="NULL" : DEFAULT$(32)="NULL" : DEFAULT$(33)="NULL"
	DEFAULT$(34)="NULL" : DEFAULT$(35)="28 DAYS"

	REM ***  BACKUP PARAMETER FILE 3  ***

4.5	N%=13 : M%=49 : FILE$="oepr3fil.201"
	IF END #N% THEN 80210
	Z%=RENAME(FILE$,"oepr3fil.101")
	IF Z%=-1 THEN GOSUB 85100 :					      \
		READ #N%,1; PR3.DATE$, PR3.DATE%, PR3.ORDER.NO%,	      \
			PR3.INVOICE.NO%, PR3.STARTOF.DAY%, PR3.ENDOF.DAY%,    \
			PR3.LASTDATE$, PR3.LASTDATE% :			      \
		CLOSE N% : END.FLAG3=0 : GOTO 14			      \
	ELSE PRINT "WARNING - PARAMETER FILE 3 DOES NOT EXIST" : END.FLAG3=1

	REM ***  GET TODAY'S DATE  ***

5	PRINT "ENTER DATE (DD/MM/YY)";
	INPUT LINE DATE$
	IF LEN(DATE$)<>8 THEN 10
	D1=VAL(LEFT$(DATE$,2)) : D2=VAL(MID$(DATE$,4,2))
	D3=VAL(RIGHT$(DATE$,2))
	IF D1<1 OR D2<1 OR D2>12 OR D3<80 THEN 10
	ON D2 GOTO 6,7,6,8,6,8,6,6,8,6,8,6

6	IF D1>31 THEN 10
	GOTO 9

7	D4=(D3/4)-(INT(D3/4))
	IF D4=0 AND D1>29 THEN 10
	IF D1>28 THEN 10
	GOTO 9

8	IF D1>30 THEN 10

9	Z$=MID$(DATE$,3,1)+MID$(DATE$,6,1)
	IF Z$<>"//" THEN 10
	IF D1=1 THEN 9.1
	D1=D1-1
	GOTO 9.5

9.1	IF D2=1 THEN D1=31 : D2=12 : D3=D3-1 : GOTO 9.5
	IF D2=2 OR D2=4 OR D2=6 OR D2=9 OR D2=11 THEN			      \
		D1=31 : D2=D2-1 : GOTO 9.5
	IF D2=3 THEN	D1=28	: D2=2 : GOTO 9.5
	D1=30 : D2=D2-1

9.5	M=D2 : D=D1 : Y=D3
	DATA 0,31,59,90,120,151,181,212,243,273,304,334
	FOR H=1 TO M : READ A : NEXT H
	A=A+Y*365+INT(Y/4)+D+1-INT(Y/100)+INT(Y/400)
	IF Y/400=INT(Y/400) THEN 11
	GOTO 12

10	PRINT "INVALID DATE"
	GOTO 5

11	IF M>2 THEN 12
	A=A-1

	REM ***  A CONTAINS THE NUMBER OF DAYS SINCE 0,0,0   ***

12	A=A-29221
	A%=INT(A)

	REM ***  SET UP PARAMETER FILE 3 DATA  ***

	PR3.DATE$      =STR$(D1)+"/"+STR$(D2)+"/"+STR$(D3)
	PR3.DATE%      =A%	  : PR3.LASTDATE$   =PR3.DATE$
	PR3.LASTDATE%  =PR3.DATE% : PR3.ORDER.NO%   =0
	PR3.INVOICE.NO%=0	  : PR3.STARTOF.DAY%=1
	PR3.ENDOF.DAY% =0

	REM ***  INPUT PARAMETER FILE 1 VALUES	***

14	ER=0 : A$="PASSWORD NO. 1" : B$=DEFAULT$(1) : GOSUB 400 : GOSUB 500
	IF ER=1 THEN 14
	Z$=UCASE$(Z$)
	PR1.PASSWORD$(1)=Z$

15	ER=0 : A$="PASSWORD NO. 2" : B$=DEFAULT$(2) : GOSUB 400 : GOSUB 500
	IF ER=1 THEN 15
	Z$=UCASE$(Z$)
	PR1.PASSWORD$(2)=Z$

20	ER=0 : A$="PASSWORD NO. 3" : B$=DEFAULT$(3) : GOSUB 400 : GOSUB 500
	IF ER=1 THEN 20
	Z$=UCASE$(Z$)
	PR1.PASSWORD$(3)=Z$

25	ER=0 : A$="CREDIT CARD CODE NO. 1" : B$=DEFAULT$(4)
	GOSUB 400 : GOSUB 550
	IF ER=1 THEN 25
	PR1.CREDCARD.CODE%(1)=Z%

30	ER=0 : A$="CREDIT CARD CODE NO. 2" : B$=DEFAULT$(5)
	GOSUB 400 : GOSUB 550
	IF ER=1 THEN 30
	PR1.CREDCARD.CODE%(2)=Z%

35	ER=0 : A$="CREDIT CARD CODE NO. 3" : B$=DEFAULT$(6)
	GOSUB 400 : GOSUB 550
	IF ER=1 THEN 35
	PR1.CREDCARD.CODE%(3)=Z%

40	ER=0 : A$="CREDIT CARD CODE NO. 4" : B$=DEFAULT$(7)
	GOSUB 400 : GOSUB 550
	IF ER=1 THEN 40
	PR1.CREDCARD.CODE%(4)=Z%

45	ER=0 : A$="CREDIT CARD NAME NO. 1" : B$=DEFAULT$(8)
	GOSUB 400 : GOSUB 600
	IF ER=1 THEN 45
	PR1.CREDCARD.NAME$(1)=Z$

50	ER=0 : A$="CREDIT CARD NAME NO. 2" : B$=DEFAULT$(9)
	GOSUB 400 : GOSUB 600
	IF ER=1 THEN 50
	PR1.CREDCARD.NAME$(2)=Z$

55	ER=0 : A$="CREDIT CARD NAME NO. 3" : B$=DEFAULT$(10)
	GOSUB 400 : GOSUB 600
	IF ER=1 THEN 55
	PR1.CREDCARD.NAME$(3)=Z$

60	ER=0 : A$="CREDIT CARD NAME NO. 4" : B$=DEFAULT$(11)
	GOSUB 400 : GOSUB 600
	IF ER=1 THEN 60
	PR1.CREDCARD.NAME$(4)=Z$

65	ER=0 : A$="AUTOMATIC ORDER NUMBERING (YES/NO)" : B$=DEFAULT$(12)
	GOSUB 400 : GOSUB 650
	IF ER=1 THEN 65
	PR1.ORDNO.GEN%=Z%
	IF Z%=0 THEN 70

66	IF PR3.ORDER.NO%=0 THEN PR3.ORDER.NO%=1
	ER=0 : A$="ORDER START NUMBER" : B$=STR$(PR3.ORDER.NO%)
	GOSUB 400 : GOSUB 525
	IF ER=1 THEN 66
	PR3.ORDER.NO%=Z%

70	ER=0 : A$="AUTOMATIC INVOICE NUMBERING (YES/NO)" : B$=DEFAULT$(13)
	GOSUB 400 : GOSUB 650
	IF ER=1 THEN 70
	PR1.INVNO.GEN%=Z%
	IF Z%=0 THEN 75

71	IF PR3.INVOICE.NO%=0 THEN PR3.INVOICE.NO%=1
	ER=0 : A$="INVOICE START NUMBER" : B$=STR$(PR3.INVOICE.NO%)
	GOSUB 400 : GOSUB 525
	IF ER=1 THEN 71
	PR3.INVOICE.NO%=Z%

75	ER=0 : A$="DISPATCH NOTE FILE DRIVE (A/B/C/D)" : B$=DEFAULT$(14)
	GOSUB 400 : GOSUB 700
	IF ER=1 THEN 75
	PR1.DISP.DRV$=Z$

80	ER=0 : A$="SUSPENSE FILE DRIVE (A/B/C/D)" : B$=DEFAULT$(15)
	GOSUB 400 : GOSUB 700
	IF ER=1 THEN 80
	PR1.SUSP.DRV$=Z$

85	ER=0 : A$="INVOICE FILE DRIVE (A/B/C/D)" : B$=DEFAULT$(16)
	GOSUB 400 : GOSUB 700
	IF ER=1 THEN 85
	PR1.INV.DRV$=Z$

90	ER=0 : A$="CREDIT CARD VERIFICATION FILE DRIVE (A/B/C/D)"
	B$=DEFAULT$(17) : GOSUB 400 : GOSUB 700
	IF ER=1 THEN 90
	PR1.CRED.DRV$=Z$

95	ER=0 : A$="LINKED STOCK FILE (YES/NO)" : B$=DEFAULT$(18)
	GOSUB 400 : GOSUB 650
	IF ER=1 THEN 95
	PR1.STOCKFIL.IND%=Z%

	IF PR1.STOCKFIL.IND%=0 THEN \
		PR1.STOCKFIL.DRV$="" : PR1.STOCKFIL.NAME$="" : GOTO 110

100	ER=0 : A$="STOCK FILE DRIVE (A/B/C/D)" : B$=DEFAULT$(19)
	GOSUB 400 : GOSUB 700
	IF ER=1 THEN 100
	PR1.STOCKFIL.DRV$=Z$

105	ER=0 : A$="STOCK FILE NAME" : B$=DEFAULT$(20) : GOSUB 400 : GOSUB 750
	IF ER=1 THEN 105
	PR1.STOCKFIL.NAME$=Z$

110	ER=0 : A$="LINKED CUSTOMER FILE (YES/NO)" : B$=DEFAULT$(21)
	GOSUB 400 : GOSUB 650
	IF ER=1 THEN 110
	PR1.CUSTFIL.IND%=Z%

	IF PR1.CUSTFIL.IND%=0 THEN \
		PR1.CUSTFIL.DRV$="" : PR1.CUSTFIL.NAME$="" : GOTO 125

115	ER=0 : A$="CUSTOMER FILE DRIVE (A/B/C/D)" : B$=DEFAULT$(22)
	GOSUB 400 : GOSUB 700
	IF ER=1 THEN 115
	PR1.CUSTFIL.DRV$=Z$

120	ER=0 : A$="CUSTOMER FILE NAME" : B$=DEFAULT$(23)
	GOSUB 400 : GOSUB 750
	IF ER=1 THEN 120
	PR1.CUSTFIL.NAME$=Z$

125	ER=0 : A$="LINKED SALES LEDGER FILE (YES/NO)" : B$=DEFAULT$(24)
	GOSUB 400 : GOSUB 650
	IF ER=1 THEN 125
	PR1.SALESFIL.IND%=Z%

	IF PR1.SALESFIL.IND%=0 THEN \
		PR1.SALESFIL.DRV$="" : PR1.SALESFIL.NAME$="" : GOTO 140

130	ER=0 : A$="SALES LEDGER FILE DRIVE (A/B/C/D)" : B$=DEFAULT$(25)
	GOSUB 400 : GOSUB 700
	IF ER=1 THEN 130
	PR1.SALESFIL.DRV$=Z$

135	ER=0 : A$="SALES LEDGER FILE NAME" : B$=DEFAULT$(26)
	GOSUB 400 : GOSUB 750
	IF ER=1 THEN 135
	PR1.SALESFIL.NAME$=Z$

140	ER=0 : A$="VDU DEFINITION FILE NAME" : B$=DEFAULT$(27)
	GOSUB 400 : GOSUB 750
	IF ER=1 THEN 140
	PR1.VDUDEF.NAME$=Z$

	REM ***  INPUT PARAMETER FILE 2 VALUES	***

150	ER=0 : A$="COMPANY NAME" : B$=DEFAULT$(28) : GOSUB 400 : GOSUB 800
	IF ER=1 THEN 150
	PR2.NAME$=Z$

155	ER=2 : A$="COMPANY ADDRESS LINE 1" : B$=DEFAULT$(29)
	GOSUB 400 : GOSUB 800
	IF ER=1 THEN 155
	PR2.ADD1$=Z$

160	ER=3 : A$="COMPANY ADDRESS LINE 2" : B$=DEFAULT$(30)
	GOSUB 400 : GOSUB 800
	IF ER=1 THEN 160
	PR2.ADD2$=Z$

165	ER=0 : A$="COMPANY ADDRESS LINE 3" : B$=DEFAULT$(31)
	GOSUB 400 : GOSUB 850
	IF ER=1 THEN 165
	PR2.ADD3$=Z$

170	ER=0 : A$="COMPANY POSTCODE" : B$=DEFAULT$(32) : GOSUB 400 : GOSUB 900
	IF ER=1 THEN 170
	PR2.POSTCODE$=Z$

175	ER=0 : A$="COMPANY TELEPHONE NUMBER" : B$=DEFAULT$(33)
	GOSUB 400 : GOSUB 950
	IF ER=1 THEN 175
	PR2.TELNO$=Z$

180	ER=0 : A$="VAT REGISTRATION NUMBER" : B$=DEFAULT$(34)
	GOSUB 400 : GOSUB 960
	IF ER=1 THEN 180
	PR2.VATREGNO$=Z$

185	ER=0 : A$="CREDIT TERMS IN DAYS" : B$=DEFAULT$(35)
	GOSUB 400 : GOSUB 970
	IF ER=1 THEN 185
	PR2.CREDIT.TERMS%=Z%

	REM ***  CREATE NEW PARAMETER FILE 1  ***

	IF END #1 THEN 80055
	GOSUB 80050
	IF END #1 THEN 80045
	GOSUB 80040

	REM *** CREATE PARAMETER FILE 2  ***

	IF END #2 THEN 80155
	GOSUB 80150
	IF END #2 THEN 80145
	GOSUB 80140

	REM ***  CREATE PARAMETER FILE 3  ***

	IF END #3 THEN 80255
	GOSUB 80250
	IF END #3 THEN 80245
	GOSUB 80240

	REM ***  END OF PROCESSING  ***

	CLOSE 1,2,3
	IF END.FLAG1=1 AND END.FLAG2=1 AND END.FLAG3=1 THEN 10000
	CHAIN "OE100"

	REM ***  INPUT SUBROUTINE  ***

400	Z$="" : PRINT A$ : PRINT "DEFAULT = "; B$; : INPUT LINE Z$
	RETURN

	REM ***  VETTING SUBROUTINES  ***

500	IF Z$=""     THEN Z$=B$                     : GOTO 510
	IF LEN(Z$)>5 THEN PRINT "PASSWORD TOO LONG" : ER=1
510	RETURN

525	IF Z$="" THEN Z%=VAL(B$) : GOTO 535
	Z=VAL(Z$)
	IF Z<1 OR Z>99999 OR Z-INT(Z)<>0 THEN \
		PRINT "INVALID NUMBER" : ER=1 : GOTO 535
	Z%=INT(Z)
535	RETURN

550	IF Z$=""      THEN Z%=VAL(B$)                        : GOTO 560
	IF LEN(Z$)<>2 THEN PRINT "CODE MUST BE 2 CHARACTERS" : ER=1\
	ELSE Z%=VAL(Z$)
560	RETURN

600	IF Z$=""      THEN Z$=B$                      : GOTO 610
	IF LEN(Z$)>16 THEN PRINT "CARD NAME TOO LONG" : ER=1
610	RETURN

650	IF Z$=""    THEN Z$=B$
	IF Z$="YES" THEN Z%=1 : GOTO 660
	IF Z$="NO"  THEN Z%=0 : GOTO 660
	PRINT "INVALID RESPONSE - ENTER YES OR NO"
	ER=1
660	RETURN

700	IF Z$="A" OR Z$="B" OR Z$="C" OR Z$="D" THEN Z$=Z$+":" : GOTO 710
	IF Z$=""                                THEN Z$=B$+":" : GOTO 710
	PRINT "INVALID DRIVE INDICATOR - MUST BE A OR B OR C OR D"
	ER=1
710	RETURN

750	IF Z$=""      THEN Z$=B$                      : GOTO 760
	IF LEN(Z$)>12 THEN PRINT "FILE NAME TOO LONG" : ER=1
760	RETURN

800	IF Z$<>""    THEN 805
	IF B$="NULL" THEN 815
	Z$=B$ : GOTO 815
805	IF LEN(Z$)<31 THEN 815
	IF ER=0 THEN PRINT "NAME TOO LONG"           : GOTO 810
	IF ER=2 THEN PRINT "ADDRESS LINE 1 TOO LONG" : GOTO 810
	IF ER=3 THEN PRINT "ADDRESS LINE 2 TOO LONG"
810	ER=1
815	RETURN

850	IF Z$="" AND B$="NULL" THEN 860
	IF Z$=""               THEN Z$=B$                           : GOTO 860
	IF LEN(Z$)>24	       THEN PRINT "ADDRESS LINE 3 TOO LONG" : ER=1
860	RETURN

900	IF Z$="" AND B$="NULL" THEN 910
	IF Z$=""               THEN Z$=B$                     : GOTO 910
	IF LEN(Z$)>9	       THEN PRINT "POSTCODE TOO LONG" : ER=1
910	RETURN

950	IF Z$="" AND B$="NULL" THEN 955
	IF Z$=""               THEN Z$=B$ : GOTO 955
	IF LEN(Z$)<14	       THEN 955
	PRINT "TELEPHONE NUMBER TOO LONG" : ER=1
955	RETURN

960	IF Z$="" AND B$="NULL" THEN 965
	IF Z$=""               THEN Z$=B$        : GOTO 965
	IF LEN(Z$)<12	       THEN 965
	PRINT "VAT REGISTRATION NUMBER TOO LONG" : ER=1
965	RETURN

970	IF Z$="" THEN Z%=VAL(LEFT$(B$,2)) : GOTO 980
	Z=VAL(Z$)
	IF Z-INT(Z)<>0 OR Z<1 OR Z>999 THEN \
		PRINT "INVALID CREDIT TERMS" : ER=1 : GOTO 980
	Z%=Z
980	RETURN

10000	STOP

%include oepr1fil
%include oepr2fil
%include oepr3fil
%include oefilsub
