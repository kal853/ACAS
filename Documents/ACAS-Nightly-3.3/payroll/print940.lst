  1656  *>
  1657  *> Will be Reading Emp History in main body
  1658  *>
  1659       initialise
  1660                WS-Accumulator-Fields.
  1661       move     zeros to WS-Tot-Renum-Paid
  1662                         WS-Over-6k.
  1663  *>
  1664       perform  forever
  1665                read     PY-History-File next record at end
  1666                         close    PY-History-File
  1667                         exit     perform
  1668                end-read
  1669  *> Acccumulate
  1670                add      His-YTD-Income-Taxable
  1671                         His-YTD-Other-Taxable
  1672                         His-YTD-Other-NonTaxable
  1673                         His-YTD-Tips  giving WS-Pay
  1674                add      WS-Pay   to  WS-Tot-Renum-Paid
ACS Cobol Xref v2.03.18          Dictionary File for PRINT940    11/03/2026  21:58:11:51                               Page   32

  1675                if       WS-Pay > Ded-Co-Futa-Limit
  1676                         compute   WS-Over-6k = WS-Pay - Ded-Co-Futa-Limit
  1677                end-if
  1678  *> Calulations
  1679                add      WS-Over-6k
  1680                         Coh-YTD-Other-NonTaxable giving WS-Exempt
  1681                move     Ded-Co-SUI-Rate         to WS-Rate9
  1682                move     Ded-Co-Futa-Max-Credit  to WS-Max-Rate9
  1683                add      Coh-YTD-Income-Taxable
  1684                         Coh-YTD-Other-Taxable
  1685                         Coh-YTD-Tips
  1686                                                  giving WS-Gross-Pay
  1687                multiply WS-Gross-Pay by Ded-Co-Futa-Max-Credit
  1688                                                  giving WS-Contrib-at-2-7
  1689                multiply WS-Gross-Pay by Ded-Co-SUI-Rate
  1690                                                  giving WS-Contrib-at-Rate
  1691                compute  WS-AddL-Credits = WS-Contrib-at-2-7 - WS-Contrib-at-Rate
  1692                if       WS-AddL-Credits negative
  1693                         move     zero to WS-AddL-Credits
  1694                end-if
  1695                move     WS-Contrib-at-Rate to WS-Actual-Contrib   *> should equal coh.ytd.co.sui.liab
  1696                compute  WS-Tot-Tent-Cred =  WS-AddL-Credits + WS-Actual-Contrib
  1697                compute  WS-Tot-Taxable-Futa = WS-Tot-Renum-Paid - WS-Exempt
  1698                compute  WS-Gross-Fed-Tax = WS-Tot-Taxable-Futa * Ded-Co-Futa-Rate
  1699                compute  WS-Maximum-Cred  = WS-Tot-Taxable-Futa * Ded-Co-Futa-Max-Credit
  1700                if       WS-Tot-Tent-Cred < WS-Maximum-Cred
  1701                         move     WS-Tot-Tent-Cred to  WS-Smaller
  1702                else
  1703                         move     WS-Maximum-Cred  to  WS-Smaller
  1704                end-if
  1705  *> Not sure about this as should be processed via RI State tax.
  1706                if       PY-PR1-Co-State = "RI"                     *> Rhode Island,  what is this?,  still valid ?
  1707                         move     WS-Tot-Taxable-Futa to WS-RI-Tax
  1708                         multiply WS-RI-Tax by 0.375 giving WS-RI-Cred   *> RI Tax at 3.75%  IS this valid ?
  1709                else
  1710                         move     zero to WS-RI-Tax
  1711                                          WS-RI-Cred
  1712                end-if
  1713                compute  WS-Cred-Allowable = WS-Smaller - WS-RI-Cred
  1714                compute  WS-Net-Fed-Tax    = WS-Gross-Fed-Tax - WS-Cred-Allowable
  1715                move     zero to WS-Tot-Deposited
  1716                         A
  1717                perform  4 times
  1718                         add      1 to A
  1719                         add      Coh-Q-Co-Futa-Liab (A) to WS-Tot-Deposited
  1720                end-perform
  1721                compute  WS-Balance-Due = WS-Net-Fed-Tax - WS-Tot-Deposited
  1722                if       WS-Balance-Due negative
  1723                         multiply WS-Balance-Due by -1 giving WS-Overpay
  1724                         move     zero to WS-Balance-Due
  1725                end-if
  1726       end-perform.
