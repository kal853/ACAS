  1513  *>**********************************
  1514  *> Force Esc, PgUp, PgDown, PrtSC to be detected
  1515       set      ENVIRONMENT "COB_SCREEN_EXCEPTIONS" to "Y".
  1516       set      ENVIRONMENT "COB_SCREEN_ESC" to "Y".
  1517       move     Current-Date to WSE-Date-block.
  1518       move     WSE-Date-9  to WS-Test-YMD.
  1519       move     Print-Spool-Name to PSN.  *> set ACAS prt spool for o/p
  1520  *>
  1521  *> Create common-date in ccyymmdd form.
  1522  *>   assuming To-Day is in Locale format ie USA mm.dd/ccyy
  1523  *>
  1524       move     To-Day (7:4)      to WS-Common-Date (1:4).
  1525       if       PY-PR1-Date-Format = 2
  1526                move To-Day (1:2) to WS-Common-Date (5:2)  *> mm
  1527                move To-Day (4:2) to WS-Common-Date (7:2)  *> dd
  1528       else
  1529                move To-Day (4:2) to WS-Common-Date (5:2)  *> mm
  1530                move To-Day (1:2) to WS-Common-Date (7:2). *> dd
  1531  *>
  1532       perform  forever
  1533                accept   WS-Env-Lines   from lines
  1534                if       WS-Env-Lines < 28
  1535                         display  SY010    at 0101 with erase eos
  1536                         accept   WS-Reply at 0133
  1537                         move     8 to WS-Term-Code
  1538                         exit perform cycle
  1539                end-if
  1540                accept   WS-Env-Columns from Columns
  1541                if       WS-Env-Columns < 80
  1542                         display  SY013    at 0101 with erase eos
  1543                         accept   WS-Reply at 0130
  1544                         move     8 to WS-Term-Code
  1545                         exit perform cycle
  1546                end-if
  1547       end-perform.
  1548  *>
  1549  *> Set up error message areas on screen anyway
  1550  *>
  1551       subtract 2 from WS-Env-Lines giving WS-22-Lines.
  1552       subtract 1 from WS-Env-Lines giving WS-23-Lines.
  1553       move     WS-Env-Lines to WS-Lines.
  1554  *>
  1555  *> Open all files if any missing Abort.
  1556  *> For all files other than His-Emp read only record.
  1557  *>
  1558       move     1 to RRN.
  1559       open     i-o      PY-Param1-File.
  1560       if       PY-PR1-Status not = "00"      *> Does not exist yet so lets create it & write rec
