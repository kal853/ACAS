000040C      perform  zz010-Get-Env-Set-Files.          *> This must be set so get it 1st + need os-delimiter
000041C *>
000042C *> See if we have temporary overrides that have been supplied when calling program
000043C *> Also possible are request to run specific progs via menu without user intervention.
000044C *>  so allowing for 2 params on the line & here param 1 can be one of:
000045C *>     'NONE', 'NULL', 'ACAS_LEDGERS='
000046C *>
000047C      move     spaces to Arg-Test
000048C                         WS-CD-Args in WS-Calling-Data.
000049C      move     1 to z.
000050C      accept   Arg-Vals from command-line.
000051C      unstring Arg-Vals delimited by space
000052C                into Arg-Test
000053C                with pointer z.
000054C    *>  move     function upper-case (Arg-Test) to Arg-Test.
000055C *>
000056C  *>    accept   Arg-Number from argument-number.
000057C  *>    if       Arg-Number = zero
000058C  *>             go to zz020-Set-the-Paths.
000059C *>
000060C      if       Arg-Test (1:5) = spaces
000061C               go to zz020-Set-the-Paths.
000062C *>
000063C  *>    if       Arg-Number > 2
000064C  *>             display SY006      at 0101 with erase eos foreground-color 3
000065C  *>             display Arg-Number at 0164 with           foreground-color 3
000066C  *>             display SY008      at 1210 with           foreground-color 3 highlight
000067C  *>             accept ws-reply    at 1243
000068C  *>             stop run.
000069C *>
000070C  *>    accept   Arg-Value (1) from argument-value.
000071C  *> MUST BE IN CASE SO..
000072C  *>    move     function upper-case (Arg-Value (1)) to Arg-Test.
000073C      if       Arg-Test (1:12) not = "ACAS_LEDGERS"
000074C          and  Arg-Test (1:4) not = "NULL" and not = "NONE"
000075C               display SY007           at 0101 with erase eos foreground-color 3
000076C               display "Arg-No="       at 0501 with foreground-color 2
000077C               display Arg-Number      at 0508 with foreground-color 2
000078C               display "Arg Val="      at 0601 with foreground-color 2
000079C               display Arg-Test (1:40) at 0609 with foreground-color 2
000080C               display SY008           at 1210 with foreground-color 3 highlight
000081C               accept ws-reply         at 1243
000082C               stop run
000083C      end-if
000084C      if       Arg-Test (1:13) = "ACAS_LEDGERS="
000085C               move FUNCTION TRIM (Arg-Test (14:487), TRAILING) to ACAS_LEDGERS  *> 31/05/23
000086C      end-if
