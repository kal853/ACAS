000022C *>
000023C      EVALUATE PY-PR1-Status
000024C           WHEN "00" MOVE "Success                  " TO WS-Eval-Msg
000025C           WHEN "02" MOVE "Success Duplicate        " TO WS-Eval-Msg
000026C           WHEN "04" MOVE "Success Incomplete       " TO WS-Eval-Msg
000027C           WHEN "05" MOVE "Success Optional, Missing" TO WS-Eval-Msg
000028C           when "06" move "Multiple Records LS      " TO WS-Eval-Msg
000029C           WHEN "07" MOVE "Success No Unit          " TO WS-Eval-Msg
000030C           when "09" move "Success LS Bad Data      " TO WS-Eval-Msg
000031C           WHEN "10" MOVE "End Of File              " TO WS-Eval-Msg
000032C           WHEN "14" MOVE "Out Of Key Range         " TO WS-Eval-Msg
000033C           WHEN "21" MOVE "Key Invalid              " TO WS-Eval-Msg
000034C           WHEN "22" MOVE "Key Exists               " TO WS-Eval-Msg
000035C           WHEN "23" MOVE "Key Not Exists           " TO WS-Eval-Msg
000036C           WHEN "24" MOVE "Key Boundary violation   " TO WS-Eval-Msg
000037C           WHEN "30" MOVE "Permanent Error          " TO WS-Eval-Msg
000038C           WHEN "31" MOVE "Inconsistent Filename    " TO WS-Eval-Msg
000039C           WHEN "34" MOVE "Boundary Violation       " TO WS-Eval-Msg
000040C           WHEN "35" MOVE "File Not Found           " TO WS-Eval-Msg
000041C           WHEN "37" MOVE "Permission Denied        " TO WS-Eval-Msg
000042C           WHEN "38" MOVE "Closed With Lock         " TO WS-Eval-Msg
000043C           WHEN "39" MOVE "Conflict Attribute       " TO WS-Eval-Msg
000044C           WHEN "41" MOVE "Already Open             " TO WS-Eval-Msg
000045C           WHEN "42" MOVE "Not Open                 " TO WS-Eval-Msg
000046C           WHEN "43" MOVE "Read Not Done            " TO WS-Eval-Msg
000047C           WHEN "44" MOVE "Record Overflow          " TO WS-Eval-Msg
000048C           WHEN "46" MOVE "Read Error               " TO WS-Eval-Msg
000049C           WHEN "47" MOVE "Input Denied             " TO WS-Eval-Msg
000050C           WHEN "48" MOVE "Output Denied            " TO WS-Eval-Msg
000051C           WHEN "49" MOVE "I/O Denied               " TO WS-Eval-Msg
000052C           WHEN "51" MOVE "Record Locked            " TO WS-Eval-Msg
000053C           WHEN "52" MOVE "End-Of-Page              " TO WS-Eval-Msg
000054C           WHEN "57" MOVE "I/O Linage               " TO WS-Eval-Msg
000055C           WHEN "61" MOVE "File Sharing Failure     " TO WS-Eval-Msg
000056C           WHEN "71" MOVE "Bad Character LS         " TO WS-Eval-Msg
000057C           WHEN "91" MOVE "Feature Not Available    " TO WS-Eval-Msg
000058C           WHEN OTHER
000059C                   MOVE "Unknown File Status      " TO WS-Eval-Msg
000060C *>
000061C      END-EVALUATE.
